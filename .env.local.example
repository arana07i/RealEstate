# Supabase — copy to .env.local and fill in from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: used for admin-only server operations (keep secret, never commit)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (optional: add when ready to bill)
STRIPE_SECRET_KEY=sk_test_your_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_PRICE_STARTER=price_starter_id
STRIPE_PRICE_PROFESSIONAL=price_professional_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_id
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email (optional: for notifications)
RESEND_API_KEY=re_your_resend_key

# Redis (optional: for distributed rate limiting)
REDIS_URL=redis://localhost:6379

# Site URL (used for redirects, webhooks)
NEXT_PUBLIC_SITE_URL=https://your-site.com
